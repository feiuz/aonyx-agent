{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aonyx",
  "version": "0.9.1",
  "identifier": "site.aonyx.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aonyx Agent",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://cdn.aonyx.fr/desktop/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0MEQ2QThEQ0RBMkNCQUIKUldTcnk2TE5qV29OOUJXOEd3UWQxc2ZwY1ZpK0J4L2xmMUpDcmM5c1Uzb1ZFcXM3eG95Wld6aGwK"
    }
  }
}
